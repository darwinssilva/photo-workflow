#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "bundler/setup"
require "webrick"
require "photo_workflow/settings"
require "photo_workflow/google_calendar_webhook_handler"
require "photo_workflow/whatsapp_webhook_handler"

host = PhotoWorkflow::Settings.value("WEBHOOK_BIND", "0.0.0.0")
port = PhotoWorkflow::Settings.integer("WEBHOOK_PORT", 4567)
path = PhotoWorkflow::Settings.value("WEBHOOK_PATH", "/google-calendar/webhook")
whatsapp_path = PhotoWorkflow::Settings.value("WHATSAPP_WEBHOOK_PATH", "/whatsapp/webhook")

handler = PhotoWorkflow::GoogleCalendarWebhookHandler.new
whatsapp_handler = PhotoWorkflow::WhatsAppWebhookHandler.new

server = WEBrick::HTTPServer.new(BindAddress: host, Port: port)

server.mount_proc(path) do |req, res|
  unless req.request_method == "POST"
    res.status = 405
    res.body = "method not allowed"
    next
  end

  headers = {}
  req.each do |name, value|
    headers[name] = value
  end

  result = handler.call(headers: headers)
  res.status = result.fetch(:status)
  res["Content-Type"] = "text/plain"
  res.body = result.fetch(:body)
end

server.mount_proc(whatsapp_path) do |req, res|
  if req.request_method == "GET"
    result = whatsapp_handler.verify(
      mode: req.query["hub.mode"],
      verify_token: req.query["hub.verify_token"],
      challenge: req.query["hub.challenge"]
    )
    res.status = result.fetch(:status)
    res["Content-Type"] = "text/plain"
    res.body = result.fetch(:body)
    next
  end

  unless req.request_method == "POST"
    res.status = 405
    res.body = "method not allowed"
    next
  end

  result = whatsapp_handler.receive(body: req.body)
  res.status = result.fetch(:status)
  res["Content-Type"] = "text/plain"
  res.body = result.fetch(:body)
end

trap("INT") { server.shutdown }
trap("TERM") { server.shutdown }

puts "Google Calendar webhook listening on http://#{host}:#{port}#{path}"
puts "WhatsApp webhook listening on http://#{host}:#{port}#{whatsapp_path}"
server.start
